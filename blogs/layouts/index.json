[
{{- range $index, $page := .Site.RegularPages -}}
{{- if $index -}}, {{- end }}
{
  "title": {{ $page.Title | jsonify }},
  "permalink": {{ $page.RelPermalink | jsonify }},
  "summary": {{ $page.Summary | plainify | jsonify }},
  "content": {{ $page.Plain | jsonify }},
  "date": {{ $page.Date.Format "Jan 02, 2006" | jsonify }}
}
{{- end -}}
]
